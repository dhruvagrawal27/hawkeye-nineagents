# =========================================================================
# HAWKEYE — environment configuration
# Copy to .env locally; on prod VPS keep at /opt/hawkeye/.env with chmod 600.
# =========================================================================

# --- Public URL (set to https://hawkeye.nineagents.in in prod) -----------
PUBLIC_BASE_URL=http://localhost:8080

# --- LLM (Groq only) ------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TIMEOUT_SECONDS=30

# --- Postgres -------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=hawkeye
POSTGRES_PASSWORD=hawkeye_dev_change_me
POSTGRES_DB=hawkeye
POSTGRES_URL=postgresql+asyncpg://hawkeye:hawkeye_dev_change_me@postgres:5432/hawkeye

# --- Redis ---------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Neo4j ---------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASS=hawkeye_neo4j_change_me

# --- Kafka ---------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_EVENTS=hawkeye.events
KAFKA_CONSUMER_GROUP=hawkeye-scorer

# --- MinIO ---------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=hawkeye
MINIO_SECRET_KEY=hawkeye_minio_change_me
MINIO_BUCKET=hawkeye

# --- Keycloak ------------------------------------------------------------
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=hawkeye
KEYCLOAK_CLIENT_ID=hawkeye-frontend
KEYCLOAK_BACKEND_CLIENT_ID=hawkeye-backend
KEYCLOAK_BACKEND_CLIENT_SECRET=
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=hawkeye_kc_admin_change_me

# --- MLflow --------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Artifacts & data ----------------------------------------------------
ARTIFACTS_DIR=artifacts
DATA_DIR=data

# --- Scoring -------------------------------------------------------------
# Loaded from feature_config.json at startup; this is a fallback only.
SCORE_THRESHOLD=0.16032509001471132
ALERT_DEDUP_WINDOW_MINUTES=60
ALERT_DEDUP_DELTA=0.05

# --- Replay --------------------------------------------------------------
REPLAY_DEFAULT_RATE=500
REPLAY_MAX_RATE=5000

# --- Frontend (Vite) -----------------------------------------------------
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=/ws
VITE_KEYCLOAK_URL=/auth
VITE_KEYCLOAK_REALM=hawkeye
VITE_KEYCLOAK_CLIENT_ID=hawkeye-frontend

# --- Preflight / debug ---------------------------------------------------
# When 1, /alerts and /internal/* skip JWT auth so preflight_check.py can
# verify them. Must be 0 in production.
PREFLIGHT_MODE=0
LOG_LEVEL=INFO
